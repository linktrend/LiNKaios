# Copy to `.env.runtime` on LiNKdroplet (same directory as docker-compose.yml).
#   cp .env.runtime.example .env.runtime
# Fill every REPLACE_* value. Never commit `.env.runtime`.
#
# Caddy (reverse-proxy) reads PUBLIC_HOSTNAME + TLS_EMAIL from this file via docker-compose `env_file`.

# --- Public site / TLS (Caddy) ---
PUBLIC_HOSTNAME=REPLACE_WITH_FQDN.example.com
TLS_EMAIL=REPLACE_WITH_LETSENCRYPT_EMAIL@yourdomain.com

# --- oauth2-proxy (OIDC; often Supabase Auth) ---
# Issuer is usually: https://<project-ref>.supabase.co/auth/v1
OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_HTTP_ADDRESS=0.0.0.0:4180
OAUTH2_PROXY_UPSTREAMS=static://202
OAUTH2_PROXY_SKIP_AUTH_PREFLIGHT=true
OAUTH2_PROXY_SKIP_PROVIDER_BUTTON=true
OAUTH2_PROXY_SCOPE=openid email profile
OAUTH2_PROXY_OIDC_ISSUER_URL=https://REPLACE_PROJECT_REF.supabase.co/auth/v1
OAUTH2_PROXY_CLIENT_ID=REPLACE_OIDC_CLIENT_ID
OAUTH2_PROXY_CLIENT_SECRET=REPLACE_OIDC_CLIENT_SECRET
# Generate: openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=REPLACE_RANDOM_32_BYTES_BASE64
# Must match external URL users hit (HTTPS, no trailing slash on host)
OAUTH2_PROXY_REDIRECT_URL=https://REPLACE_WITH_FQDN.example.com/oauth2/callback
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_COOKIE_SECURE=true
OAUTH2_PROXY_COOKIE_SAMESITE=lax
OAUTH2_PROXY_SET_XAUTHREQUEST=true
OAUTH2_PROXY_PASS_ACCESS_TOKEN=true
OAUTH2_PROXY_PASS_AUTHORIZATION_HEADER=true

# --- Paperclip (container: ghcr.io/paperclipai/paperclip) ---
HOST=0.0.0.0
# External URL operators use in the browser (scheme + host, no trailing slash)
PAPERCLIP_PUBLIC_URL=https://REPLACE_WITH_FQDN.example.com
# Generate: openssl rand -base64 48
BETTER_AUTH_SECRET=REPLACE_RANDOM_LONG_SECRET
# Optional provider keys (Paperclip features); leave empty if unused
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- LiNKaios (@linktrend/LiNKaios) — non-secret + GSM secret names ---
PORT=4000
SUPABASE_URL=https://REPLACE_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_SECRET_NAME=LINKTREND_AIOS_PROD_SUPABASE_SERVICE_ROLE
AIOS_INGRESS_TOKEN_SECRET_NAME=AIOS_INGRESS_TOKEN
N8N_WEBHOOK_URL=https://REPLACE_N8N_PUBLIC_HOST/webhook/aios/urgent-event
NATS_URL=nats://host.docker.internal:4222
LINKSKILLS_API_URL=http://host.docker.internal:8081
LINKSKILLS_API_TOKEN_SECRET_NAME=LINKSKILLS_API_TOKEN
LINKSKILLS_PRINCIPAL_ID=linktrend-internal-agent
LINKSKILLS_BILLING_TRACK=track_1
LINKSKILLS_VENTURE_ID=linktrend_internal
LINKSKILLS_DEFAULT_STEP_SCOPE=phase.execute
SLACK_OPERATIONS_WEBHOOK_SECRET_NAME=SLACK_OPERATIONS_WEBHOOK_URL
SLACK_APPROVALS_WEBHOOK_SECRET_NAME=SLACK_APPROVALS_WEBHOOK_URL
SLACK_CHANNEL_OPERATIONS=#aios-ops
SLACK_CHANNEL_APPROVALS=#aios-approvals
SLACK_CHANNEL_STRATEGIC=#linkaios_approvals
SLACK_CHANNEL_OPERATIONAL=#linkaios_ops
SLACK_CHANNEL_QUALITY=#linkaios_ops
CHAIRMAN_APPROVAL_TIME=08:00
OPERATIONAL_PULSE_TIME=10:45
QUALITY_GATE_TIME=14:45
CHAIRMAN_APPROVAL_TIMEZONE=Asia/Taipei
POSTMARK_SERVER_TOKEN_SECRET_NAME=LINKTREND_AIOS_PROD_POSTMARK_SERVER_TOKEN
OPENROUTER_API_KEY_SECRET_NAME=LINKTREND_AIOS_PROD_OPENROUTER_API_KEY
ANTHROPIC_API_KEY_SECRET_NAME=LINKTREND_AIOS_PROD_ANTHROPIC_API_KEY
OLLAMA_EMBEDDING_URL=http://host.docker.internal:11434/api/embeddings
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
LINKBOARD_URL=http://host.docker.internal:3200/council/synthesis
AIOS_CHAIRMAN_BRIEFING_URL=http://linkaios:4000/briefings/chairman/daily?tenantId=00000000-0000-0000-0000-000000000001
GOOGLE_CLOUD_PROJECT=linkbot-901208
GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/google/linktrend-gsm.json
