{
  "name": "AIOS Heartbeat Triage",
  "nodes": [
    {
      "name": "Heartbeat Trigger",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "httpMethod": "POST",
        "path": "aios/heartbeat/triage"
      }
    },
    {
      "name": "Load Mission Health",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "url": "={{$env.SUPABASE_HEALTH_RPC}}",
        "method": "POST",
        "sendBody": true,
        "jsonBody": "={\"tenant_id\": $json.tenantId}"
      }
    },
    {
      "name": "Build Priority Packet",
      "type": "n8n-nodes-base.function",
      "parameters": {
        "functionCode": "const data = items[0].json;\nreturn [{ json: { tenantId: data.tenantId, summary: data.summary || 'Heartbeat triage packet', blockers: data.blockers || [], risk: data.risk || 'unknown' } }];"
      }
    },
    {
      "name": "Notify CEO CTO Slack",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "url": "={{$env.SLACK_OPERATIONS_WEBHOOK_URL}}",
        "method": "POST",
        "sendBody": true,
        "jsonBody": "={{ { text: '[Heartbeat Triage] ' + $json.summary } }}"
      }
    }
  ],
  "connections": {
    "Heartbeat Trigger": {
      "main": [
        [
          {
            "node": "Load Mission Health",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Load Mission Health": {
      "main": [
        [
          {
            "node": "Build Priority Packet",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Priority Packet": {
      "main": [
        [
          {
            "node": "Notify CEO CTO Slack",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
